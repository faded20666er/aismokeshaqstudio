# Copy this to .env.local for local development.
# In production, set these as Environment Variables in the Vercel dashboard
# (Project Settings -> Environment Variables) — never commit real secrets.

# Clerk authentication (get these from dashboard.clerk.com -> API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Owner testing bypass — comma-separated list of userId values to treat
# as having unlimited credits (so you can test without spending real
# credits). Once you sign up via Clerk, your real userId will look like
# "user_xxxxxxxxxxxxxxxxxxxx" — find it in the Clerk dashboard under
# Users, or check the browser devtools/network tab on a request from
# your own logged-in session. Put that value here, e.g.:
#   OWNER_USER_IDS=user_2abc123xyz
OWNER_USER_IDS=

# Replicate — note the name is REPLICATE_API_TOKEN, not REPLICATE_API_KEY.
# The old .env had REPLICATE_API_KEY, but every API route calls
# process.env.REPLICATE_API_TOKEN, so the old key was silently never read.
REPLICATE_API_TOKEN=your_replicate_token_here

# Hugging Face inference API
HUGGINGFACE_API_KEY=your_huggingface_key_here

# WaveSpeed (used for InfiniteTalk talking-photo models)
WAVESPEED_API_KEY=your_wavespeed_key_here

# Upstash Redis (used for the credits store)
KV_REST_API_URL=your_upstash_redis_rest_url_here
KV_REST_API_TOKEN=your_upstash_redis_rest_token_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_signing_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Stripe Price IDs for each subscription tier
STRIPE_PRICE_STARTER=price_1Tksn3P8Ys6gPzq4P1lw7eL8
STRIPE_PRICE_PRO=price_REPLACE_ME
STRIPE_PRICE_PREMIUM=price_REPLACE_ME

PORT=3001
