# Environment variables example for the site

# Database for NextAuth/Prisma (SQLite for local testing)
DATABASE_URL="file:./dev.db"

# NextAuth secret
NEXTAUTH_SECRET="replace-with-a-long-random-string"

# Google OAuth (create credentials in Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# SMTP for email magic links (Mailtrap/Ethereal for development)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# Owner email who receives unlimited credits for testing
OWNER_EMAIL="faded20666@gmail.com"

# Upstash Redis (or existing KV env names used in the project)
KV_REST_API_URL=""
KV_REST_API_TOKEN=""
# Alternative env names sometimes used in the code
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Starting credits for anonymous vs verified users
ANON_STARTING_CREDITS=20
VERIFIED_STARTING_CREDITS=45
